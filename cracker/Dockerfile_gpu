# Start with the official NVIDIA CUDA base image
FROM nvidia/cuda:12.8.0-devel-ubuntu24.04

ENV DEBIAN_FRONTEND=noninteractive
ENV PYTHONUNBUFFERED=1

# ---> THE MAGIC BRIDGE <---
# Manually create the OpenCL routing file so Hashcat can find the injected NVIDIA drivers
RUN mkdir -p /etc/OpenCL/vendors && echo "libnvidia-opencl.so.1" > /etc/OpenCL/vendors/nvidia.icd
# --------------------------

RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    python3 \
    python3-pip \
    ocl-icd-libopencl1 \
    ocl-icd-opencl-dev \
    clinfo \
    git \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/* \
    && cd /opt \
    && git clone https://github.com/hashcat/hashcat.git \
    && cd hashcat \
    && make \
    && ln -s /opt/hashcat/hashcat /usr/local/bin/hashcat

WORKDIR /app

COPY requirements.txt .
RUN pip3 install --no-cache-dir --break-system-packages -r requirements.txt

COPY . .
CMD ["python3", "cracker_service.py"]